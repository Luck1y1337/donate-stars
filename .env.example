# Telegram bot token from @BotFather
BOT_TOKEN=

# Your numeric Telegram id (from @userinfobot) — receives admin rights
ADMIN_ID=

# file_id of the "thank you" sticker (optional, leave empty to disable)
THANK_YOU_STICKER_ID=

# Path to the SQLite database file.
# Local default is fine; for Docker use /data/bot.db with a mounted volume.
DB_PATH=bot.db
